<UserControl x:Class="Deskbridge.Dialogs.GroupEditorContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    MaxWidth="480">

    <StackPanel Margin="16,12">
        <TextBlock Text="Group name" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
            PlaceholderText="Group name" Margin="0,0,0,12" />

        <TextBlock Text="Parent group" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding AvailableParentGroups}"
            SelectedValue="{Binding ParentGroupId}"
            SelectedValuePath="Id"
            DisplayMemberPath="DisplayName" Margin="0,0,0,16" />

        <!-- Credentials section -->
        <TextBlock Text="Group credentials" FontSize="16" FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4" />
        <TextBlock Text="Set credentials here to share them with all connections in this group"
            FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12" />

        <TextBlock Text="Username" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding CredentialUsername}"
            PlaceholderText="username (leave empty for no group credentials)" Margin="0,0,0,12" />

        <TextBlock Text="Domain" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding CredentialDomain}"
            PlaceholderText="domain (optional)" Margin="0,0,0,12" />

        <TextBlock Text="Password" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <PasswordBox x:Name="GroupPasswordBox"
            PasswordChanged="GroupPasswordBox_PasswordChanged" Margin="0,0,0,12" />

        <!-- Inheritance count -->
        <ui:InfoBar Title="Inheritance"
            Message="{Binding InheritanceCount, StringFormat='{}{0} connection(s) will inherit these credentials'}"
            Severity="Informational"
            IsOpen="{Binding ShowInheritanceCount, Mode=OneWay}"
            IsClosable="False" />
    </StackPanel>
</UserControl>
