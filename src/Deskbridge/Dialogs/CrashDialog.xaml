<ui:ContentDialog x:Class="Deskbridge.Dialogs.CrashDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    mc:Ignorable="d"
    Title="Deskbridge encountered an unexpected error"
    DialogMaxWidth="480"
    PrimaryButtonText="Copy Details"
    PrimaryButtonAppearance="Secondary"
    CloseButtonText="Restart"
    CloseButtonAppearance="Primary">

    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:CrashDialog}" />
    </ui:ContentDialog.Resources>

    <!-- UI-SPEC §Crash Dialog Internal Layout (lines 149-161). No stack trace
         visible — details flow to the clipboard via Copy Details. -->
    <StackPanel>
        <TextBlock FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Text="An unexpected error occurred. A log file with details has been saved to your AppData folder. You can copy the error details to clipboard for support, or restart the application." />
    </StackPanel>
</ui:ContentDialog>
