<ui:ContentDialog x:Class="Deskbridge.Dialogs.CredentialPromptDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    xmlns:ctrl="clr-namespace:Deskbridge.Controls"
    Title="Connect"
    DialogMaxWidth="420"
    PrimaryButtonText="Connect"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- Pitfall 1: custom ContentDialog subclass requires BasedOn style. -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:CredentialPromptDialog}" />
    </ui:ContentDialog.Resources>

    <StackPanel Margin="0,8">
        <!-- Hostname header — read-only, shows what you're connecting to -->
        <TextBlock x:Name="HostnameText"
                   Style="{StaticResource CardTitleStyle}"
                   TextWrapping="Wrap"
                   Margin="{StaticResource SectionSpacing}" />

        <!-- Username -->
        <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
        <ui:TextBox x:Name="UsernameBox"
                    PlaceholderText="Username"
                    Margin="{StaticResource FormFieldSpacing}" />

        <!-- Password -->
        <TextBlock x:Name="PasswordLabel" Text="Password" Style="{StaticResource FieldLabelStyle}" />
        <PasswordBox x:Name="PasswordBox"
                     Margin="{StaticResource FormFieldSpacing}" />

        <!-- PIN (hidden by default — shown via UsePinMode()) -->
        <ctrl:PinInputControl x:Name="PinField"
                              Visibility="Collapsed"
                              Margin="{StaticResource FormFieldSpacing}" />

        <!-- Domain -->
        <TextBlock Text="Domain" Style="{StaticResource FieldLabelStyle}" />
        <ui:TextBox x:Name="DomainBox"
                    PlaceholderText="Domain (optional)"
                    Margin="{StaticResource FormFieldLabelMargin}" />
    </StackPanel>
</ui:ContentDialog>
