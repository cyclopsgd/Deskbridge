<ui:ContentDialog x:Class="Deskbridge.Dialogs.CredentialPromptDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    Title="Connect"
    DialogMaxWidth="420"
    PrimaryButtonText="Connect"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- Pitfall 1: custom ContentDialog subclass requires BasedOn style. -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:CredentialPromptDialog}" />
    </ui:ContentDialog.Resources>

    <StackPanel Margin="0,8">
        <!-- Hostname header — read-only, shows what you're connecting to -->
        <TextBlock x:Name="HostnameText"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <!-- Username -->
        <TextBlock Text="Username" FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,4" />
        <ui:TextBox x:Name="UsernameBox"
                    PlaceholderText="Username"
                    Margin="0,0,0,12" />

        <!-- Password -->
        <TextBlock Text="Password" FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox"
                     Margin="0,0,0,12" />

        <!-- Domain -->
        <TextBlock Text="Domain" FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,4" />
        <ui:TextBox x:Name="DomainBox"
                    PlaceholderText="Domain (optional)"
                    Margin="0,0,0,4" />
    </StackPanel>
</ui:ContentDialog>
