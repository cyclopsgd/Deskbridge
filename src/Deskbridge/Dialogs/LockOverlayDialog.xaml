<ui:ContentDialog x:Class="Deskbridge.Dialogs.LockOverlayDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    mc:Ignorable="d"
    IsFooterVisible="False"
    Background="{DynamicResource ApplicationBackgroundBrush}">

    <!-- BasedOn style for WPF-UI theming (Pitfall 1: ContentDialog subclasses need this). -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:LockOverlayDialog}" />
    </ui:ContentDialog.Resources>

    <!--
        Task 0 Wave 0 spike (Q4) — MINIMAL SHELL ONLY. Full layout lands in Task 2
        per UI-SPEC §Lock Overlay Internal Layout. Purpose of this file right now
        is to prove IsFooterVisible=False + opaque ApplicationBackgroundBrush hide
        the ContentDialog chrome + footer without a stray title-bar "X".
    -->
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Width="360" Padding="32" CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Deskbridge"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Wave 0 visual spike — Q4 chrome verification."
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,8,0,24" />
                <ui:Button Content="Unlock" Appearance="Primary"
                           Height="40" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>
    </Grid>
</ui:ContentDialog>
