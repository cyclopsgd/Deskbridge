<ui:ContentDialog x:Class="Deskbridge.Dialogs.GroupEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    Title="{Binding DialogTitle}"
    DialogMaxWidth="480"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- BasedOn style for WPF-UI theming -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:GroupEditorDialog}" />
    </ui:ContentDialog.Resources>

    <!-- Single panel layout (no tabs per D-12) -->
    <StackPanel Margin="{StaticResource DialogContentMargin}">

        <!-- Group Name -->
        <TextBlock Text="Group name" Style="{StaticResource FieldLabelStyle}" />
        <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
            PlaceholderText="Group name" Margin="{StaticResource FormFieldSpacing}" />

        <!-- Parent Group -->
        <TextBlock Text="Parent group" Style="{StaticResource FieldLabelStyle}" />
        <!--
             Explicit ItemTemplate forces SelectionBoxItem to use the same
             rendering as dropdown items; otherwise SelectedValuePath="Id" leaves
             SelectionBoxItem as the raw Guid, which WPF-UI's ComboBox template
             renders as "- - -" placeholder glyphs.
        -->
        <ComboBox ItemsSource="{Binding AvailableParentGroups}"
            SelectedValue="{Binding ParentGroupId}"
            SelectedValuePath="Id" Margin="{StaticResource FormFieldSpacing}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Separator -->
        <Border Style="{StaticResource SeparatorStyle}" />

        <!-- Section header -->
        <TextBlock Text="Group Credentials" Style="{StaticResource CardTitleStyle}" />

        <!-- Helper text -->
        <TextBlock Text="Credentials set here will be inherited by all connections in this group unless overridden."
            Style="{StaticResource CaptionStyle}"
            TextWrapping="Wrap"
            Margin="0,4,0,12" />

        <!-- Username -->
        <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
        <ui:TextBox Text="{Binding CredentialUsername}"
            PlaceholderText="username" Margin="{StaticResource FormFieldSpacing}" />

        <!-- Domain -->
        <TextBlock Text="Domain" Style="{StaticResource FieldLabelStyle}" />
        <ui:TextBox Text="{Binding CredentialDomain}"
            PlaceholderText="domain (optional)" Margin="{StaticResource FormFieldSpacing}" />

        <!-- Password -->
        <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
        <PasswordBox x:Name="GroupPasswordBox" Margin="{StaticResource FormFieldSpacing}" />

        <!-- Inheritance count (shown only when credentials are set) -->
        <TextBlock Text="{Binding InheritanceCount, StringFormat='{}{0} connections will inherit these credentials'}"
            Style="{StaticResource CaptionStyle}"
            Visibility="{Binding ShowInheritanceCount, Converter={StaticResource BoolToVisibility}}" />

    </StackPanel>
</ui:ContentDialog>
