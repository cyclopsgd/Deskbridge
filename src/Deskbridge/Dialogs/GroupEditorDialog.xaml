<ui:ContentDialog x:Class="Deskbridge.Dialogs.GroupEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    Title="{Binding DialogTitle}"
    DialogMaxWidth="480"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- BasedOn style for WPF-UI theming -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:GroupEditorDialog}" />
    </ui:ContentDialog.Resources>

    <!-- Single panel layout (no tabs per D-12) -->
    <StackPanel Margin="16,12">

        <!-- Group Name -->
        <TextBlock Text="Group name" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
            PlaceholderText="Group name" Margin="0,0,0,12" />

        <!-- Parent Group -->
        <TextBlock Text="Parent group" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding AvailableParentGroups}"
            SelectedValue="{Binding ParentGroupId}"
            SelectedValuePath="Id"
            DisplayMemberPath="DisplayName" Margin="0,0,0,12" />

        <!-- Separator -->
        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,12" />

        <!-- Section header -->
        <TextBlock Text="Group Credentials" FontSize="16" FontWeight="SemiBold" />

        <!-- Helper text -->
        <TextBlock Text="Credentials set here will be inherited by all connections in this group unless overridden."
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
            Margin="0,4,0,12" />

        <!-- Username -->
        <TextBlock Text="Username" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding CredentialUsername}"
            PlaceholderText="username" Margin="0,0,0,12" />

        <!-- Domain -->
        <TextBlock Text="Domain" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding CredentialDomain}"
            PlaceholderText="domain (optional)" Margin="0,0,0,12" />

        <!-- Password -->
        <TextBlock Text="Password" FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
        <PasswordBox x:Name="GroupPasswordBox" Margin="0,0,0,12" />

        <!-- Inheritance count (shown only when credentials are set) -->
        <TextBlock Text="{Binding InheritanceCount, StringFormat='{}{0} connections will inherit these credentials'}"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Visibility="{Binding ShowInheritanceCount, Converter={StaticResource BoolToVisibility}}" />

    </StackPanel>
</ui:ContentDialog>
