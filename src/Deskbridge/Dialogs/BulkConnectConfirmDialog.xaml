<ui:ContentDialog x:Class="Deskbridge.Dialogs.BulkConnectConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    Title="Connect all connections?"
    DialogMaxWidth="420"
    PrimaryButtonText="Connect All"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- BasedOn style for WPF-UI theming -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:BulkConnectConfirmDialog}" />
    </ui:ContentDialog.Resources>

    <StackPanel Margin="{StaticResource DialogContentMargin}" MinWidth="340">

        <!-- Title row: amber Warning24 glyph beside the heading. -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Warning24"
                Foreground="{DynamicResource DeskbridgeWarningBrush}"
                FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="Many active sessions"
                Style="{StaticResource BodyStyle}"
                VerticalAlignment="Center" />
        </StackPanel>

        <!-- WR-04: the parameterized count+threshold sentence is the SINGLE source of warning
             copy. It is injected from ctor params (x:Name) into the InfoBar's Message below so
             there is exactly one visible copy (no static duplicate that can drift). -->

        <!-- GDI warning InfoBar (non-destructive operation: Warning severity, not Error/Danger).
             Message is the dynamic count+threshold sentence set from the ctor. -->
        <ui:InfoBar x:Name="WarningInfoBar"
            Severity="Warning"
            Title="Many active sessions"
            IsOpen="True"
            IsClosable="False" />

    </StackPanel>
</ui:ContentDialog>
