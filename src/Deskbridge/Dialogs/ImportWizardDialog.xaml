<ui:ContentDialog x:Class="Deskbridge.Dialogs.ImportWizardDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    xmlns:vm="clr-namespace:Deskbridge.ViewModels"
    xmlns:models="clr-namespace:Deskbridge.Core.Models;assembly=Deskbridge.Core"
    Title="Import Connections"
    DialogMaxWidth="560"
    PrimaryButtonText="{Binding PrimaryButtonText}"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <!-- BasedOn style for WPF-UI theming (Pitfall 1) -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:ImportWizardDialog}" />
    </ui:ContentDialog.Resources>

    <Grid MinWidth="440" MinHeight="200">
        <!-- Step 1: Source Selection -->
        <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Import from:" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding AvailableImporters}"
                      SelectedItem="{Binding SelectedImporter}"
                      DisplayMemberPath="SourceName"
                      MinWidth="200" />
            <TextBlock Text="Select the application to import connections from."
                       Style="{StaticResource CaptionStyle}"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- Step 2: File Picker -->
        <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Select configuration file:" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding FilePath}" IsReadOnly="True" />
                <ui:Button Grid.Column="1" Content="Browse..."
                           Command="{Binding BrowseFileCommand}" Margin="8,0,0,0" />
            </Grid>
            <!-- Error display for invalid/encrypted files -->
            <ui:InfoBar IsOpen="{Binding ErrorMessage, Converter={StaticResource NullToBool}}"
                        Severity="Error" Title="Import Error"
                        Message="{Binding ErrorMessage}" Margin="0,8,0,0"
                        IsClosable="False" />
        </StackPanel>

        <!-- Step 3: Tree Preview with Checkboxes -->
        <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,8">
                <Run Text="Select connections to import:" />
            </TextBlock>
            <TreeView Grid.Row="1" ItemsSource="{Binding PreviewItems}"
                      MaxHeight="300" MinHeight="200">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Protocol}" Margin="8,0,0,0"
                                       Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Step 4: Confirmation/Summary
             Phase 22 Plan 22-02 (UI-SPEC §"Severity Selection Rule" + §"InfoBar copy"):
             Severity + Title bind to VM computed properties driven by FailedCount /
             ImportedCount. Failure-list section visible iff FailedCount > 0; overflow
             footer visible iff FailedCount > 50. -->
        <StackPanel Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisibility}}">
            <ui:InfoBar IsOpen="True"
                        IsClosable="False"
                        Severity="{Binding ImportSeverity}"
                        Title="{Binding ImportTitleText}"
                        Message="{Binding ImportSummary}" />

            <!-- Failure-list section heading — visible iff FailedCount > 0 -->
            <TextBlock Text="Failed Connections"
                       Style="{StaticResource CardTitleStyle}"
                       Margin="0,16,0,8"
                       Visibility="{Binding FailedCount, Converter={StaticResource IntToVisibility}}" />

            <!-- Failure list — visible iff FailedCount > 0; capped at MaxHeight=180 -->
            <ItemsControl ItemsSource="{Binding Failures}"
                          MaxHeight="180"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding FailedCount, Converter={StaticResource IntToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                            <TextBlock Text="{Binding ConnectionName}"
                                       Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text=": "
                                       Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{Binding Detail}"
                                       Style="{StaticResource ErrorTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="4,0,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Overflow footer — visible iff FailedCount > 50 -->
            <TextBlock Style="{StaticResource HintStyle}"
                       Margin="0,4,0,0">
                <TextBlock.Text>
                    <Binding Path="FailedCount"
                             Converter="{StaticResource OverflowMoreText}"
                             ConverterParameter="50" />
                </TextBlock.Text>
                <TextBlock.Visibility>
                    <Binding Path="FailedCount"
                             Converter="{StaticResource IntGreaterThanToVisibility}"
                             ConverterParameter="50" />
                </TextBlock.Visibility>
            </TextBlock>
        </StackPanel>

        <!-- Processing overlay
             Phase 22 Plan 22-02 (IMP-03 / UI-SPEC §"Progress Surface — Layout"):
             forked branches by IsImportWriteInProgress.
              - Parse phase (existing): indeterminate ProgressRing + "Processing..."
              - Write phase (Phase 22 new): determinate ProgressBar + "{N} of {Total}" caption -->
        <Grid Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}" Opacity="0.7" />

            <!-- Parse-phase indicator (preserved verbatim per UI-SPEC §"Parse-phase indicator").
                 Visible only during parse, NOT during write. -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsImportWriteInProgress, Converter={StaticResource InverseBoolToVisibility}}">
                <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32" />
                <TextBlock Text="Processing..." Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Style="{StaticResource BodyMutedStyle}" />
            </StackPanel>

            <!-- Phase 22 (IMP-03): determinate write-phase progress -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsImportWriteInProgress, Converter={StaticResource BoolToVisibility}}">
                <!-- Standard WPF ProgressBar — WPF-UI 4.2 does not ship a
                     ui:ProgressBar control (only ui:ProgressRing). The control
                     auto-restyles via WPF-UI's ControlsDictionary. -->
                <ProgressBar Minimum="0"
                             Maximum="{Binding TotalToImport}"
                             Value="{Binding ImportedCount}"
                             IsIndeterminate="False"
                             MinWidth="320"
                             Height="4" />
                <TextBlock Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Style="{StaticResource BodyMutedStyle}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} of {1}">
                            <Binding Path="ImportedCount" />
                            <Binding Path="TotalToImport" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</ui:ContentDialog>
