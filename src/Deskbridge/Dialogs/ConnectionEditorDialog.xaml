<ui:ContentDialog x:Class="Deskbridge.Dialogs.ConnectionEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Deskbridge.Dialogs"
    xmlns:models="clr-namespace:Deskbridge.Core.Models;assembly=Deskbridge.Core"
    Title="{Binding DialogTitle}"
    DialogMaxWidth="560"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonAppearance="Primary"
    DefaultButton="Primary">

    <!-- BasedOn style for WPF-UI theming -->
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:ConnectionEditorDialog}" />
    </ui:ContentDialog.Resources>

    <!-- Content: TabControl with 4 tabs -->
    <TabControl SelectedIndex="0">

        <!-- Tab 1: General -->
        <TabItem Header="General">
            <StackPanel Margin="{StaticResource DialogContentMargin}" MinHeight="320">
                <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Connection name" Margin="{StaticResource FormFieldSpacing}" />

                <TextBlock Text="Hostname" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="hostname or IP" Margin="{StaticResource FormFieldSpacing}" />

                <TextBlock Text="Port" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="3389" Margin="{StaticResource FormFieldSpacing}" />

                <TextBlock Text="Group" Style="{StaticResource FieldLabelStyle}" />
                <!--
                     Explicit ItemTemplate is required so that SelectionBoxItem (the
                     collapsed selection visual) uses the same template as the open
                     dropdown. When only SelectedValuePath + DisplayMemberPath are set,
                     WPF-UI's ComboBox template renders SelectionBoxItem as the raw
                     VALUE (the Guid/enum), producing the "- - -" placeholder glyphs.
                -->
                <ComboBox ItemsSource="{Binding AvailableGroups}"
                    SelectedValue="{Binding GroupId}"
                    SelectedValuePath="Id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </TabItem>

        <!-- Tab 2: Credentials (D-11, D-13, CONN-09) -->
        <TabItem Header="Credentials">
            <StackPanel Margin="{StaticResource DialogContentMargin}" MinHeight="320">
                <TextBlock Text="Credential mode" Style="{StaticResource FieldLabelStyle}" />
                <!--
                     Explicit ItemTemplate forces SelectionBoxItem (collapsed visual)
                     to use the same template as the dropdown items. Without this,
                     SelectedValuePath="Value" causes SelectionBoxItem to be the raw
                     enum, which WPF-UI's ComboBox template renders as "- - -"
                     placeholder glyphs.
                -->
                <ComboBox ItemsSource="{Binding CredentialModes}"
                    SelectedValue="{Binding CredentialMode}"
                    SelectedValuePath="Value"
                    Margin="{StaticResource FormFieldSpacing}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- InfoBar for Inherit mode (D-13, CONN-09) -->
                <ui:InfoBar Title="Inherited credentials"
                    Message="{Binding InheritedFromMessage}"
                    Severity="Informational"
                    IsOpen="{Binding IsInheritInfoBarVisible, Mode=OneWay}"
                    IsClosable="False"
                    Margin="{StaticResource FormFieldSpacing}" />

                <!-- InfoBar for Prompt mode -->
                <ui:InfoBar Title="Prompt mode"
                    Message="You will be asked for credentials each time you connect."
                    Severity="Warning"
                    IsOpen="{Binding IsPromptInfoBarVisible, Mode=OneWay}"
                    IsClosable="False"
                    Margin="{StaticResource FormFieldSpacing}" />

                <!-- Credential fields (visible when not Prompt, enabled when Own) -->
                <StackPanel Visibility="{Binding IsCredentialFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                    <ui:TextBox Text="{Binding Username}"
                        PlaceholderText="username"
                        IsEnabled="{Binding IsCredentialFieldsEnabled}" Margin="{StaticResource FormFieldSpacing}" />

                    <!-- Layer 1: "Password saved" button -->
                    <ui:Button Content="Password saved"
                        Command="{Binding ShowPasswordActionsCommand}"
                        Visibility="{Binding ShowPasswordSavedButton, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Appearance="Secondary"
                        Margin="{StaticResource FormFieldSpacing}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="LockClosed24" />
                        </ui:Button.Icon>
                    </ui:Button>

                    <!-- Layer 2: Change / Clear options + undo -->
                    <Grid Visibility="{Binding ShowPasswordOptions, Converter={StaticResource BoolToVisibility}}"
                          Margin="{StaticResource FormFieldSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Change"
                            Command="{Binding StartPasswordChangeCommand}"
                            HorizontalAlignment="Stretch" Margin="0,0,4,0"
                            Appearance="Secondary">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Edit24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Grid.Column="1" Content="Clear"
                            Command="{Binding ClearPasswordCommand}"
                            HorizontalAlignment="Stretch" Margin="4,0,4,0"
                            Appearance="Secondary">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Delete24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Grid.Column="2" Appearance="Transparent"
                            Command="{Binding CancelPasswordChangeCommand}"
                            Width="32" Height="32" Padding="0"
                            ToolTip="Back">
                            <ui:SymbolIcon Symbol="ArrowUndo24" />
                        </ui:Button>
                    </Grid>

                    <!-- Layer 3: Password entry fields (new connections, or after clicking Change) -->
                    <StackPanel Visibility="{Binding ShowPasswordFields, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                        <ui:PasswordBox x:Name="PasswordBox"
                            IsEnabled="{Binding IsCredentialFieldsEnabled}"
                            Margin="{StaticResource FormFieldSpacing}" />

                        <TextBlock Text="Confirm Password" Style="{StaticResource FieldLabelStyle}" />
                        <ui:PasswordBox x:Name="ConfirmPasswordBox"
                            IsEnabled="{Binding IsCredentialFieldsEnabled}"
                            Margin="{StaticResource FormFieldSpacing}" />

                        <TextBlock Text="{Binding PasswordMismatchError}"
                            Style="{StaticResource ErrorTextStyle}"
                            Margin="{StaticResource FormFieldSpacing}" />

                        <ui:Button Content="Cancel"
                            Command="{Binding CancelPasswordChangeCommand}"
                            Visibility="{Binding IsChangingPassword, Converter={StaticResource BoolToVisibility}}"
                            Appearance="Transparent"
                            HorizontalAlignment="Right"
                            Padding="8,4" FontSize="12" />
                    </StackPanel>

                    <TextBlock Text="Domain" Style="{StaticResource FieldLabelStyle}" />
                    <ui:TextBox Text="{Binding Domain}"
                        PlaceholderText="domain (optional)"
                        IsEnabled="{Binding IsCredentialFieldsEnabled}" />
                </StackPanel>
            </StackPanel>
        </TabItem>

        <!-- Tab 3: Display -->
        <TabItem Header="Display">
            <StackPanel Margin="{StaticResource DialogContentMargin}" MinHeight="320">
                <TextBlock Text="Resolution" Style="{StaticResource FieldLabelStyle}" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding DisplayWidth}"
                        PlaceholderText="Auto" />
                    <ui:TextBox Grid.Column="2" Text="{Binding DisplayHeight}"
                        PlaceholderText="Auto" />
                </Grid>
                <TextBlock Text="Leave blank to match viewport size" Style="{StaticResource HintStyle}"
                    Margin="{StaticResource FormFieldSpacing}" />

                <ui:ToggleSwitch IsChecked="{Binding SmartSizing}" Content="Smart sizing" />
            </StackPanel>
        </TabItem>

        <!-- Tab 4: Notes -->
        <TabItem Header="Notes">
            <ui:TextBox Text="{Binding Notes}" AcceptsReturn="True"
                TextWrapping="Wrap" MinHeight="320" Margin="{StaticResource DialogContentMargin}"
                VerticalScrollBarVisibility="Auto"
                PlaceholderText="Add notes about this connection..." />
        </TabItem>

    </TabControl>
</ui:ContentDialog>
