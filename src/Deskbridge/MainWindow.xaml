<ui:FluentWindow x:Class="Deskbridge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:Deskbridge.Models"
    xmlns:behaviors="clr-namespace:Deskbridge.Behaviors"
    xmlns:controls="clr-namespace:Deskbridge.Controls"
    Title="{Binding Title}"
    Icon="Assets/app.ico"
    Width="1100" Height="700"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <!-- Keyboard shortcuts -->
    <ui:FluentWindow.InputBindings>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ConnectionTree.NewConnectionCommand}" />
        <!-- NOTE: Ctrl+Tab and Ctrl+Shift+Tab cannot be reliably bound via XAML KeyBinding
             (WPF intercepts them for tab navigation). These will be wired in Phase 5
             via code-behind PreviewKeyDown handling when tabs are functional. -->
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: TitleBar (32px) -->
            <RowDefinition Height="*" />     <!-- Row 1: Main content area -->
            <RowDefinition Height="22" />    <!-- Row 2: Status bar -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Deskbridge" Height="32" />

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36" />    <!-- Column 0: Icon rail -->
                <ColumnDefinition Width="Auto" />  <!-- Column 1: Slide-out panel -->
                <ColumnDefinition Width="*" />     <!-- Column 2: Editor area -->
            </Grid.ColumnDefinitions>

            <!-- Icon Rail (Column 0) -->
            <Border Grid.Column="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Settings button pinned to bottom (VS Code convention, D-05) -->
                    <ui:Button DockPanel.Dock="Bottom"
                        Appearance="Transparent"
                        Icon="{ui:SymbolIcon Settings24}"
                        Width="36" Height="36"
                        Padding="0"
                        Command="{Binding TogglePanelCommand}"
                        CommandParameter="{x:Static models:PanelMode.Settings}"
                        AutomationProperties.Name="Settings">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                <Setter Property="BorderThickness" Value="2,0,0,0" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <!-- Top icons: Connections and Search -->
                    <StackPanel>
                        <ui:Button
                            Appearance="Transparent"
                            Icon="{ui:SymbolIcon PlugConnected24}"
                            Width="36" Height="36"
                            Padding="0"
                            Command="{Binding TogglePanelCommand}"
                            CommandParameter="{x:Static models:PanelMode.Connections}"
                            AutomationProperties.Name="Connections">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnectionsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>

                        <ui:Button
                            Appearance="Transparent"
                            Icon="{ui:SymbolIcon Search24}"
                            Width="36" Height="36"
                            Padding="0"
                            Command="{Binding TogglePanelCommand}"
                            CommandParameter="{x:Static models:PanelMode.Search}"
                            AutomationProperties.Name="Search">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Slide-out Panel (Column 1) -->
            <Border Grid.Column="1"
                Width="240"
                Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Panel header -->
                    <ContentControl DockPanel.Dock="Top">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock Text="CONNECTIONS" FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Margin="12,8" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePanelMode}" Value="{x:Static models:PanelMode.Search}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="SEARCH" FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Margin="12,8" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActivePanelMode}" Value="{x:Static models:PanelMode.Settings}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="SETTINGS" FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Margin="12,8" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <!-- Panel content area (Grid with visibility-switched children) -->
                    <Grid>
                        <!-- Connections panel: ConnectionTreeControl injected via code-behind -->
                        <ContentControl x:Name="ConnectionsContent"
                            Visibility="{Binding IsConnectionsActive, Converter={StaticResource BoolToVisibility}}" />

                        <!-- Search placeholder -->
                        <TextBlock Text="Search will appear here"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibility}}" />

                        <!--
                            Phase 6 Plan 06-04 (SEC-03 / SEC-05): Security section per UI-SPEC
                            §Settings Panel Additions (lines 182-196). Replaces the Phase 2
                            "Settings will appear here" placeholder. SecuritySettingsRecord is
                            bound via MainWindowViewModel.AutoLockTimeoutMinutes / LockOnMinimise
                            with persistence through IWindowStateService (Plan 06-02 NOTF-04).
                        -->
                        <StackPanel Margin="12,8,12,12"
                                    Visibility="{Binding IsSettingsActive, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SECURITY"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,8,0,4" />
                            <Border Padding="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <!-- Require Password/PIN toggle -->
                                    <TextBlock Text="Require password/PIN"
                                               FontSize="14" />
                                    <ui:ToggleSwitch IsChecked="{Binding RequireMasterPassword}"
                                                     Margin="0,4,0,12" />

                                    <!-- Separator -->
                                    <Border Height="1" Margin="0,0,0,12"
                                            Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                                    <!-- Auto-lock controls greyed out when password disabled -->
                                    <StackPanel IsEnabled="{Binding IsLockControlsEnabled}">
                                        <TextBlock Text="Auto-lock timeout"
                                                   FontSize="14"
                                                   Margin="0,0,0,4" />
                                        <ui:NumberBox Minimum="1" Maximum="1440"
                                                      Value="{Binding AutoLockTimeoutMinutes, UpdateSourceTrigger=LostFocus}"
                                                      Margin="0,0,0,12" />
                                        <TextBlock Text="Lock on minimise"
                                                   FontSize="14" />
                                        <ui:ToggleSwitch IsChecked="{Binding LockOnMinimise}"
                                                         Margin="0,4,0,12" />

                                        <!-- Separator -->
                                        <Border Height="1" Margin="0,0,0,12"
                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                                        <!-- Change Password/PIN button -->
                                        <ui:Button x:Name="ChangePasswordButton"
                                                   Content="{Binding ChangePasswordLabel}"
                                                   Appearance="Secondary"
                                                   HorizontalAlignment="Stretch"
                                                   Click="ChangePasswordButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Phase 7 Plan 07-04: DATA section for import/export -->
                            <TextBlock Text="DATA" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,16,0,4" />
                            <Border Padding="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <ui:Button Content="Import Connections..."
                                               Icon="{ui:SymbolIcon ArrowImport24}"
                                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                               Click="ImportConnectionsButton_Click" />
                                    <ui:Button Content="Export as JSON"
                                               Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                               Click="ExportJsonButton_Click" />
                                    <ui:Button Content="Export as CSV"
                                               Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                               HorizontalAlignment="Stretch"
                                               Click="ExportCsvButton_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Editor Area (Column 2) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />  <!-- Row 0: Tab bar -->
                    <RowDefinition Height="*" />   <!-- Row 1: Viewport -->
                </Grid.RowDefinitions>

                <!-- Tab Bar (Editor Row 0, D-06 custom, D-07 always visible) -->
                <Border Grid.Row="0"
                    Height="30"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tabs}"
                            behaviors:TabReorderBehavior.EnableReorder="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="30" Padding="8,0"
                                        Background="Transparent" Cursor="Hand"
                                        BorderThickness="0,2,0,0"
                                        ToolTip="{Binding TooltipText}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <!-- Plan 05-03 UI-SPEC line 231: inactive tabs had no hover visual. Add subtle hover. -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <!-- D-07 context menu: Close / Close Others / Close All. No icons, no separators, no extra items. -->
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Close"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                                <MenuItem Header="Close Others"
                                                    Command="{Binding DataContext.CloseOtherTabsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                                <MenuItem Header="Close All"
                                                    Command="{Binding DataContext.CloseAllTabsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="MiddleClick"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                            <MouseBinding MouseAction="LeftClick"
                                                Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- D-12 Connecting indicator (12px ProgressRing). Mutually exclusive with amber/red dots. -->
                                            <ui:ProgressRing IsIndeterminate="True"
                                                Width="12" Height="12" Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}" />
                                            <!-- D-12 Reconnecting dot (8px amber Ellipse, DeskbridgeWarningBrush #FFCC02). -->
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Fill="{DynamicResource DeskbridgeWarningBrush}"
                                                Visibility="{Binding IsReconnecting, Converter={StaticResource BoolToVisibility}}" />
                                            <!-- D-12 Error dot (8px red Ellipse, DeskbridgeErrorBrush #F44747). -->
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Fill="{DynamicResource DeskbridgeErrorBrush}"
                                                Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}" />
                                            <!-- Tab title. UI-SPEC §Tab Bar Internal Layout: MinWidth 96, MaxWidth 240, CharacterEllipsis. -->
                                            <TextBlock Text="{Binding Title}" FontSize="14"
                                                MinWidth="96" MaxWidth="240"
                                                TextTrimming="CharacterEllipsis"
                                                VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <Setter Property="FontWeight" Value="Regular" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ui:Button Appearance="Transparent"
                                                Icon="{ui:SymbolIcon Dismiss16}"
                                                Width="16" Height="16" Margin="4,0,0,0"
                                                Padding="0"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Viewport (Editor Row 1, D-08 empty state, SHEL-07 airspace-safe) -->
                <Border Grid.Row="1"
                    Background="{DynamicResource ApplicationBackgroundBrush}">
                    <Grid x:Name="ViewportGrid">
                        <!-- Empty-state placeholder (kept from Phase 2) -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasNoTabs, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Deskbridge" FontSize="20" FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center" />
                            <TextBlock Text="Ctrl+N to create a connection" FontSize="14"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                HorizontalAlignment="Center" Margin="0,8,0,0" />
                        </StackPanel>
                        <!-- Snapshot Image for drag/resize (RDP-09, D-13). Collapsed by default;
                             AirspaceSwapper toggles on WM_ENTERSIZEMOVE / WM_EXITSIZEMOVE. -->
                        <Image x:Name="ViewportSnapshot" Stretch="Fill" Visibility="Collapsed" />
                        <!-- Phase 5 D-04: persistent multi-host container. Every WindowsFormsHost
                             is parented HERE exactly once on HostMounted and removed ONLY on
                             HostUnmounted (tab close). Tab switch toggles Visibility per child
                             via MainWindow.xaml.cs SetActiveHostVisibility (Tag-keyed). NEVER
                             re-parent a WFH after AxHost init — tears down HwndSource, breaks
                             the RDP session, and can trigger UCEERR_RENDERTHREADFAILURE
                             (dotnet/wpf #3719). See WINFORMS-HOST-AIRSPACE §Option 3. -->
                        <Grid x:Name="HostContainer" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar (Root Grid Row 2) -->
        <Border Grid.Row="2"
            Background="{DynamicResource SystemAccentColorPrimaryBrush}">
            <DockPanel Margin="8,0">
                <TextBlock DockPanel.Dock="Right"
                    Text="{Binding StatusSecondary}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    VerticalAlignment="Center" FontSize="12"
                    HorizontalAlignment="Right" />

                <!-- Phase 7 Plan 07-01 (UPD-02): update badge — visible when update available.
                     ArrowDownload24 icon + version text. Clicking triggers download + confirm. -->
                <Button DockPanel.Dock="Right"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding ApplyUpdateCommand}"
                    ToolTip="{Binding UpdateVersion, StringFormat='Update v{0} available — click to download'}"
                    Background="Transparent" BorderThickness="0"
                    Padding="4,0" Margin="4,0" Cursor="Hand"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24"
                            FontSize="14"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding UpdateVersion, StringFormat='v{0}'}"
                            FontSize="11" Margin="4,0,0,0"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Phase 7 Plan 07-01 (UPD-02): download progress indicator.
                     Replaces badge during download. ProgressRing + percentage text. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"
                    Margin="4,0">
                    <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True" />
                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0}%'}"
                        FontSize="11" Margin="4,0,0,0"
                        Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding StatusText}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    VerticalAlignment="Center" FontSize="12" />
            </DockPanel>
        </Border>

        <!-- Overlay hosts (LAST children for correct Z-order per Pitfall 4) -->
        <!-- Phase 5 SnackbarPresenter retained — ConnectionTreeViewModel line 686 raises
             the 15-session warning through ISnackbarService. Phase 6 bus events route
             through the new ToastStackControl instead (see Q1 Option B in 06-02). -->
        <ui:SnackbarPresenter x:Name="SnackbarPresenter" Grid.Row="0" Grid.RowSpan="3" />
        <!-- Phase 6 Plan 06-02 (NOTF-01): custom bottom-right toast stack (max 3 visible,
             newest on top, 4th evicts oldest, hover-pause). DataContext is bound to the
             MainWindowViewModel.ToastStack singleton so ToastSubscriptionService and
             the XAML template share the same ObservableCollection. -->
        <controls:ToastStackControl x:Name="ToastStack"
                                    Grid.Row="0" Grid.RowSpan="3"
                                    DataContext="{Binding ToastStack}" />
        <ui:ContentDialogHost x:Name="RootContentDialog" Grid.Row="0" Grid.RowSpan="3" />
    </Grid>
</ui:FluentWindow>
