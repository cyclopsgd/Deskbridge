<!-- [diag rdp-black-screen-v2 H7 test] WindowBackdropType set to None to test Mica regression hypothesis. Revert to "Mica" if test confirms Mica is not the cause. -->
<ui:FluentWindow x:Class="Deskbridge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:Deskbridge.Models"
    xmlns:behaviors="clr-namespace:Deskbridge.Behaviors"
    xmlns:controls="clr-namespace:Deskbridge.Controls"
    Title="{Binding Title}"
    Icon="Assets/app.ico"
    Width="1100" Height="700"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <!-- Keyboard shortcuts -->
    <ui:FluentWindow.InputBindings>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ConnectionTree.NewConnectionCommand}" />
        <!-- NOTE: Ctrl+Tab and Ctrl+Shift+Tab cannot be reliably bound via XAML KeyBinding
             (WPF intercepts them for tab navigation). These will be wired in Phase 5
             via code-behind PreviewKeyDown handling when tabs are functional. -->
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: TitleBar (32px) -->
            <RowDefinition Height="*" />     <!-- Row 1: Main content area -->
            <RowDefinition Height="22" />    <!-- Row 2: Status bar -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Deskbridge" Height="32" />

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36" />    <!-- Column 0: Icon rail -->
                <ColumnDefinition Width="Auto" />  <!-- Column 1: Slide-out panel -->
                <ColumnDefinition Width="*" />     <!-- Column 2: Editor area -->
            </Grid.ColumnDefinitions>

            <!-- Icon Rail (Column 0) -->
            <Border Grid.Column="0"
                Background="{DynamicResource DeskbridgePanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelEdgeGradientVertical}"
                BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Settings button pinned to bottom (VS Code convention, D-05) -->
                    <Border DockPanel.Dock="Bottom" CornerRadius="4">
                        <Border.Background>
                            <SolidColorBrush x:Name="SettingsBtnBrush" Color="Transparent" />
                        </Border.Background>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard x:Name="SettingsHoverEnter">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="SettingsBtnBrush"
                                            Storyboard.TargetProperty="Color"
                                            To="{StaticResource SubtleFillColorSecondary}"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard x:Name="SettingsHoverExit">
                                    <Storyboard FillBehavior="Stop">
                                        <ColorAnimation Storyboard.TargetName="SettingsBtnBrush"
                                            Storyboard.TargetProperty="Color"
                                            To="Transparent"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <ui:Button
                            Appearance="Transparent"
                            Icon="{ui:SymbolIcon Settings24}"
                            Width="36" Height="36"
                            Padding="0"
                            Command="{Binding TogglePanelCommand}"
                            CommandParameter="{x:Static models:PanelMode.Settings}"
                            AutomationProperties.Name="Settings">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </Border>

                    <!-- Top icons: Connections and Search -->
                    <StackPanel>
                        <Border CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush x:Name="ConnBtnBrush" Color="Transparent" />
                            </Border.Background>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard x:Name="ConnHoverEnter">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ConnBtnBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="{StaticResource SubtleFillColorSecondary}"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard x:Name="ConnHoverExit">
                                        <Storyboard FillBehavior="Stop">
                                            <ColorAnimation Storyboard.TargetName="ConnBtnBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="Transparent"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <ui:Button
                                Appearance="Transparent"
                                Icon="{ui:SymbolIcon PlugConnected24}"
                                Width="36" Height="36"
                                Padding="0"
                                Command="{Binding TogglePanelCommand}"
                                CommandParameter="{x:Static models:PanelMode.Connections}"
                                AutomationProperties.Name="Connections">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                        <Setter Property="BorderThickness" Value="2,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnectionsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </Border>

                        <!-- Search icon hidden — feature not yet implemented -->
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Slide-out Panel (Column 1) -->
            <Border Grid.Column="1"
                Width="240"
                Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource DeskbridgePanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelEdgeGradientVertical}"
                BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Panel header -->
                    <ContentControl DockPanel.Dock="Top">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock Text="CONNECTIONS"
                                            Style="{StaticResource SectionLabelStyle}"
                                            Margin="12,8" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePanelMode}" Value="{x:Static models:PanelMode.Search}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="SEARCH"
                                                    Style="{StaticResource SectionLabelStyle}"
                                                    Margin="12,8" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActivePanelMode}" Value="{x:Static models:PanelMode.Settings}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="SETTINGS"
                                                    Style="{StaticResource SectionLabelStyle}"
                                                    Margin="12,8" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <!-- Panel content area (Grid with visibility-switched children) -->
                    <Grid>
                        <!-- Connections panel: ConnectionTreeControl injected via code-behind -->
                        <ContentControl x:Name="ConnectionsContent"
                            Visibility="{Binding IsConnectionsActive, Converter={StaticResource BoolToVisibility}}" />

                        <!-- Search placeholder -->
                        <TextBlock Text="Search will appear here"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibility}}" />

                        <!--
                            Phase 6 Plan 06-04 (SEC-03 / SEC-05): Security section per UI-SPEC
                            §Settings Panel Additions (lines 182-196). Replaces the Phase 2
                            "Settings will appear here" placeholder. SecuritySettingsRecord is
                            bound via MainWindowViewModel.AutoLockTimeoutMinutes / LockOnMinimise
                            with persistence through IWindowStateService (Plan 06-02 NOTF-04).
                        -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsSettingsActive, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="{StaticResource PanelContentMargin}">

                            <!-- Phase 14 Plan 14-02 (UX-02): Appearance section for text scaling -->
                            <TextBlock Text="APPEARANCE"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="{StaticResource SectionLabelMargin}" />
                            <Border Style="{StaticResource CardContainerStyle}">
                                <StackPanel>
                                    <TextBlock Text="Text size"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding TextScaleOptions}"
                                              SelectedValue="{Binding TextScale}"
                                              SelectedValuePath="Value"
                                              Margin="{StaticResource FormFieldSpacing}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="SECURITY"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0,16,0,4" />
                            <Border Style="{StaticResource CardContainerStyle}">
                                <StackPanel>
                                    <!-- Require Password/PIN toggle -->
                                    <TextBlock Text="Require password/PIN"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap" />
                                    <ui:ToggleSwitch IsChecked="{Binding RequireMasterPassword}"
                                                     Margin="0,4,0,12" />

                                    <!-- Separator -->
                                    <Border Style="{StaticResource SeparatorStyle}" />

                                    <!-- Auto-lock controls greyed out when password disabled -->
                                    <StackPanel IsEnabled="{Binding IsLockControlsEnabled}">
                                        <TextBlock Text="Auto-lock timeout"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <ui:NumberBox Minimum="1" Maximum="1440"
                                                      Value="{Binding AutoLockTimeoutMinutes, UpdateSourceTrigger=LostFocus}"
                                                      Margin="{StaticResource FormFieldSpacing}" />
                                        <TextBlock Text="Lock on minimise"
                                                   Style="{StaticResource BodyStyle}"
                                                   TextWrapping="Wrap" />
                                        <ui:ToggleSwitch IsChecked="{Binding LockOnMinimise}"
                                                         Margin="0,4,0,12" />

                                        <!-- Separator -->
                                        <Border Style="{StaticResource SeparatorStyle}" />

                                        <!-- Change Password/PIN button -->
                                        <ui:Button x:Name="ChangePasswordButton"
                                                   Content="{Binding ChangePasswordLabel}"
                                                   Appearance="Secondary"
                                                   HorizontalAlignment="Stretch"
                                                   Click="ChangePasswordButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Phase 18 Plan 18-03: BULK OPERATIONS section (D-04/D-05) -->
                            <TextBlock Text="BULK OPERATIONS"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0,16,0,4" />
                            <Border Style="{StaticResource CardContainerStyle}">
                                <StackPanel>
                                    <TextBlock Text="Confirm before bulk operations"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap" />
                                    <ui:ToggleSwitch IsChecked="{Binding ConfirmBeforeBulkOperations}"
                                                     Margin="0,4,0,12" />

                                    <!-- Separator -->
                                    <Border Style="{StaticResource SeparatorStyle}" />

                                    <TextBlock Text="Session limit warning"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding SessionLimitOptions}"
                                              SelectedValue="{Binding GdiWarningThreshold}"
                                              SelectedValuePath="Value"
                                              Margin="{StaticResource FormFieldSpacing}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Phase 7 Plan 07-04: DATA section for import/export -->
                            <TextBlock Text="DATA"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0,16,0,4" />
                            <Border Style="{StaticResource CardContainerStyle}">
                                <StackPanel>
                                    <ui:Button Content="Import Connections..."
                                               Icon="{ui:SymbolIcon ArrowImport24}"
                                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                               Click="ImportConnectionsButton_Click" />
                                    <ui:Button Content="Export as JSON"
                                               Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                               Click="ExportJsonButton_Click" />
                                    <ui:Button Content="Export as CSV"
                                               Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                               HorizontalAlignment="Stretch"
                                               Click="ExportCsvButton_Click" />
                                </StackPanel>
                            </Border>

                            <!-- Phase 18 Plan 18-03: UNINSTALL section (D-07/D-08/D-09) -->
                            <TextBlock Text="UNINSTALL"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Margin="0,16,0,4" />
                            <Border Style="{StaticResource CardContainerStyle}">
                                <StackPanel>
                                    <TextBlock Text="Clean up application data on uninstall"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap" />
                                    <ui:ToggleSwitch IsChecked="{Binding CleanUpOnUninstall}"
                                                     Margin="0,4,0,4" />
                                    <TextBlock Text="Removes connections, credentials, logs, and settings from %AppData% during uninstall."
                                               Style="{StaticResource HintStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Editor Area (Column 2) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />  <!-- Row 0: Tab bar -->
                    <RowDefinition Height="*" />   <!-- Row 1: Viewport -->
                </Grid.RowDefinitions>

                <!-- Tab Bar (Editor Row 0, D-06 custom, D-07 always visible) -->
                <Border Grid.Row="0"
                    Height="30"
                    Background="{DynamicResource DeskbridgePanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelEdgeGradientHorizontal}"
                    BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tabs}"
                            behaviors:TabReorderBehavior.EnableReorder="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TabBorder" Height="30" Padding="8,0"
                                        Margin="0,0,1,0"
                                        Cursor="Hand"
                                        BorderThickness="0,2,0,0"
                                        ToolTip="{Binding TooltipText}">
                                        <!-- TAB-01v2: Named brush for Storyboard animation targeting (Phase 10 pattern) -->
                                        <Border.Background>
                                            <SolidColorBrush x:Name="TabBrush" Color="Transparent" />
                                        </Border.Background>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </Style>
                                        </Border.Style>

                                        <!-- D-07 context menu: Close / Close Others / Close All. No icons, no separators, no extra items. -->
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Close"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                                <MenuItem Header="Close Others"
                                                    Command="{Binding DataContext.CloseOtherTabsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                                <MenuItem Header="Close All"
                                                    Command="{Binding DataContext.CloseAllTabsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="MiddleClick"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                            <MouseBinding MouseAction="LeftClick"
                                                Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        </Border.InputBindings>

                                        <Grid>
                                            <!-- TAB-03v2: State tint overlay (behind content, does not compete with hover/active animation) -->
                                            <Rectangle x:Name="StateTint" Opacity="0.05" IsHitTestVisible="False"
                                                Margin="-8,0,-8,0">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Fill" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Connected">
                                                                <Setter Property="Fill" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Reconnecting">
                                                                <Setter Property="Fill" Value="{DynamicResource DeskbridgeWarningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Error">
                                                                <Setter Property="Fill" Value="{DynamicResource DeskbridgeErrorBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>

                                            <!-- Existing content (StackPanel with indicators + title + close button) -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- D-12 Connecting indicator (12px ProgressRing). Mutually exclusive with amber/red dots. -->
                                                <ui:ProgressRing IsIndeterminate="True"
                                                    Width="12" Height="12" Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}" />
                                                <!-- D-12 Reconnecting dot (8px amber Ellipse, DeskbridgeWarningBrush #FFCC02). -->
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Fill="{DynamicResource DeskbridgeWarningBrush}"
                                                    Visibility="{Binding IsReconnecting, Converter={StaticResource BoolToVisibility}}" />
                                                <!-- D-12 Error dot (8px red Ellipse, DeskbridgeErrorBrush #F44747). -->
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Fill="{DynamicResource DeskbridgeErrorBrush}"
                                                    Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}" />
                                                <!-- Tab title. UI-SPEC §Tab Bar Internal Layout: MinWidth 96, MaxWidth 240, CharacterEllipsis. -->
                                                <TextBlock Text="{Binding Title}" FontSize="14"
                                                    MinWidth="96" MaxWidth="240"
                                                    TextTrimming="CharacterEllipsis"
                                                    VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            <Setter Property="FontWeight" Value="Regular" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- TAB-02v2: Close button hidden by default (Opacity=0), revealed on hover via DataTemplate.Triggers -->
                                                <ui:Button x:Name="CloseBtn" Appearance="Transparent"
                                                    Icon="{ui:SymbolIcon Dismiss16}"
                                                    Width="16" Height="16" Margin="4,0,0,0"
                                                    Padding="0" Opacity="0"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- TAB-01v2/02v2: DataTemplate-level triggers for cross-element Storyboard animation.
                                         Hover trigger BEFORE active DataTrigger so active takes precedence (WPF: later trigger wins). -->
                                    <DataTemplate.Triggers>
                                        <!-- Hover: animate TabBrush background + fade in close button -->
                                        <Trigger SourceName="TabBorder" Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard x:Name="HoverEnter">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="TabBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="{StaticResource SubtleFillColorSecondary}"
                                                            Duration="0:0:0.15" />
                                                        <DoubleAnimation Storyboard.TargetName="CloseBtn"
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="1" Duration="0:0:0.15" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard x:Name="HoverExit">
                                                    <Storyboard FillBehavior="Stop">
                                                        <ColorAnimation Storyboard.TargetName="TabBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="Transparent"
                                                            Duration="0:0:0.15" />
                                                        <DoubleAnimation Storyboard.TargetName="CloseBtn"
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0" Duration="0:0:0.15" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>

                                        <!-- Active tab: animate background + set accent border + keep close button visible -->
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="ActiveEnter">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="TabBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="{StaticResource SubtleFillColorSecondary}"
                                                            Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard x:Name="ActiveExit">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="TabBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="Transparent"
                                                            Duration="0:0:0.15" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                            <Setter TargetName="CloseBtn" Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Viewport (Editor Row 1, D-08 empty state, SHEL-07 airspace-safe) -->
                <Border Grid.Row="1"
                    Background="{DynamicResource ApplicationBackgroundBrush}">
                    <Grid x:Name="ViewportGrid">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasNoTabs, Converter={StaticResource BoolToVisibility}}">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="48"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="Deskbridge"
                                Style="{StaticResource SubtitleStyle}"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center" />
                            <TextBlock Text="Open a connection to get started"
                                Style="{StaticResource HintStyle}"
                                HorizontalAlignment="Center" Margin="0,4,0,16" />
                            <ui:Button Content="New Connection"
                                Appearance="Secondary"
                                Icon="{ui:SymbolIcon Add24}"
                                Command="{Binding ConnectionTree.NewConnectionCommand}"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                        <!-- Snapshot Image for drag/resize (RDP-09, D-13). Collapsed by default;
                             AirspaceSwapper toggles on WM_ENTERSIZEMOVE / WM_EXITSIZEMOVE. -->
                        <Image x:Name="ViewportSnapshot" Stretch="Fill" Visibility="Collapsed" />
                        <!-- Phase 5 D-04: persistent multi-host container. Every WindowsFormsHost
                             is parented HERE exactly once on HostMounted and removed ONLY on
                             HostUnmounted (tab close). Tab switch toggles Visibility per child
                             via MainWindow.xaml.cs SetActiveHostVisibility (Tag-keyed). NEVER
                             re-parent a WFH after AxHost init — tears down HwndSource, breaks
                             the RDP session, and can trigger UCEERR_RENDERTHREADFAILURE
                             (dotnet/wpf #3719). See WINFORMS-HOST-AIRSPACE §Option 3. -->
                        <Grid x:Name="HostContainer" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar (Root Grid Row 2) -->
        <Border Grid.Row="2"
            Background="{DynamicResource SystemAccentColorPrimaryBrush}">
            <DockPanel Margin="{StaticResource StatusBarContentMargin}">
                <TextBlock DockPanel.Dock="Right"
                    Text="{Binding StatusSecondary}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    VerticalAlignment="Center" FontSize="12"
                    HorizontalAlignment="Right" />

                <!-- Phase 7 Plan 07-01 (UPD-02): update badge — visible when update available.
                     ArrowDownload24 icon + version text. Clicking triggers download + confirm. -->
                <Button DockPanel.Dock="Right"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding ApplyUpdateCommand}"
                    ToolTip="{Binding UpdateVersion, StringFormat='Update v{0} available — click to download'}"
                    Background="Transparent" BorderThickness="0"
                    Padding="4,0" Margin="4,0" Cursor="Hand"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24"
                            FontSize="14"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding UpdateVersion, StringFormat='v{0}'}"
                            FontSize="11" Margin="4,0,0,0"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Phase 7 Plan 07-01 (UPD-02): download progress indicator.
                     Replaces badge during download. ProgressRing + percentage text. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"
                    Margin="4,0">
                    <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True" />
                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0}%'}"
                        FontSize="11" Margin="4,0,0,0"
                        Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding StatusText}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    VerticalAlignment="Center" FontSize="12" />
            </DockPanel>
        </Border>

        <!-- Overlay hosts (LAST children for correct Z-order per Pitfall 4) -->
        <!-- Phase 5 SnackbarPresenter retained — ConnectionTreeViewModel line 686 raises
             the 15-session warning through ISnackbarService. Phase 6 bus events route
             through the new ToastStackControl instead (see Q1 Option B in 06-02). -->
        <ui:SnackbarPresenter x:Name="SnackbarPresenter" Grid.Row="0" Grid.RowSpan="3" />
        <!-- Phase 6 Plan 06-02 (NOTF-01): custom bottom-right toast stack (max 3 visible,
             newest on top, 4th evicts oldest, hover-pause). DataContext is bound to the
             MainWindowViewModel.ToastStack singleton so ToastSubscriptionService and
             the XAML template share the same ObservableCollection. -->
        <controls:ToastStackControl x:Name="ToastStack"
                                    Grid.Row="0" Grid.RowSpan="3"
                                    DataContext="{Binding ToastStack}" />
        <ui:ContentDialogHost x:Name="RootContentDialog" Grid.Row="0" Grid.RowSpan="3" />
    </Grid>
</ui:FluentWindow>
