<Application x:Class="Deskbridge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:Deskbridge.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/CardAndPanelStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Custom semantic brushes (per SHEL-08) -->
            <SolidColorBrush x:Key="DeskbridgeErrorBrush" Color="#F44747" />
            <SolidColorBrush x:Key="DeskbridgeSuccessBrush" Color="#89D185" />

            <!-- Phase 3 additions -->
            <SolidColorBrush x:Key="DeskbridgeWarningBrush" Color="#FFCC02" />

            <!-- Standard converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <converters:TreeViewItemIndentConverter x:Key="TreeViewItemIndent" IndentSize="19" />
            <converters:BoolToChevronConverter x:Key="BoolToChevron" />
            <converters:EnumToVisibilityConverter x:Key="EnumToVisibility" />
            <converters:NullToCollapsedConverter x:Key="NullToCollapsed" />
            <converters:NullToBoolConverter x:Key="NullToBool" />

            <!-- POLISH-02 (D-08): MenuItem hover color consistency.
                 WPF-UI's internal MenuItem template provides fade transitions.
                 This style ensures the highlight color matches the established
                 SubtleFillColorSecondary used by tree rows and tabs.
                 Named style (not implicit) per Phase 8 convention. Applied via
                 ContextMenu.ItemContainerStyle on each ContextMenu instance. -->
            <Style x:Key="AnimatedMenuItemStyle" TargetType="MenuItem"
                   BasedOn="{StaticResource {x:Type MenuItem}}">
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background"
                                Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
