<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- POLISH-03 (D-04/D-05/D-06): Gradient border brushes for panel edge elevation.
         "Lit from above" effect: visible at top/left, fading to transparent at ~30%.
         CRITICAL: Use Color key (ControlStrokeColorDefault), not Brush key.
         See WPF-UI-PITFALLS.md Pitfall 5 for Color vs Brush key distinction. -->

    <!-- Vertical edge gradient: for right-edge borders (icon rail, slide-out panel).
         Gradient goes top (visible) to bottom (transparent). -->
    <LinearGradientBrush x:Key="PanelEdgeGradientVertical"
        StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.3" />
    </LinearGradientBrush>

    <!-- Horizontal edge gradient: for horizontal borders (tab bar bottom, properties panel top).
         Gradient goes left (visible) to right (transparent). -->
    <LinearGradientBrush x:Key="PanelEdgeGradientHorizontal"
        StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.3" />
    </LinearGradientBrush>

</ResourceDictionary>
