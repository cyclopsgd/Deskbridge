<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Semantic fill hierarchy for layered depth (FOUND-03):
        Layer 0: Mica backdrop (ApplicationBackgroundBrush) - the window itself
        Layer 1: Panel fill - icon rail, slide-out panel, tab bar
        Layer 2: Card fill - settings cards, properties sections, toast containers
        Layer 3: Input fill - text fields and combo boxes inside cards (WPF-UI built-in)

        WPF-UI token mapping:
        - ControlFillColorDefault  = ~6% white overlay (panels on Mica)
        - ControlFillColorSecondary = ~8% white overlay (cards on panels)

        CRITICAL: Use Color keys (not Brush keys) for SolidColorBrush.Color binding.
    -->
    <SolidColorBrush x:Key="DeskbridgePanelBackgroundBrush"
                     Color="{DynamicResource ControlFillColorDefault}" />
    <SolidColorBrush x:Key="DeskbridgeCardBackgroundBrush"
                     Color="{DynamicResource ControlFillColorSecondary}" />

    <!-- Card container style (settings cards, property sections) -->
    <Style x:Key="CardContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource DeskbridgeCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Panel border style (slide-out panel, icon rail) -->
    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource DeskbridgePanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    </Style>

    <!-- Separator line -->
    <Style x:Key="SeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="Margin" Value="{StaticResource FormFieldSpacing}" />
    </Style>

    <!-- Toast container style -->
    <Style x:Key="ToastContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="360" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{DynamicResource DeskbridgeCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Quick properties header strip -->
    <Style x:Key="PanelHeaderStyle" TargetType="Border">
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>

    <!-- Phase 9 (PROP-01): Toggle button for collapsible card section headers.
         Strips WPF-UI's ToggleButton chrome (hover gradient, check indicator)
         and renders content directly. Used with a Grid containing SectionLabelStyle
         text + chevron icon. Cursor=Hand signals clickability. -->
    <Style x:Key="CardHeaderToggleStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <ContentPresenter
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Margin="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- POLISH-03 (D-04/D-05/D-06): Gradient border brushes for panel edge elevation.
         "Lit from above" effect: visible at top/left, fading to transparent at ~30%.
         CRITICAL: Use Color key (ControlStrokeColorDefault), not Brush key. -->
    <LinearGradientBrush x:Key="PanelEdgeGradientVertical"
        StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.3" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PanelEdgeGradientHorizontal"
        StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.3" />
    </LinearGradientBrush>

    <!-- Softer variant for narrow panels where the full gradient reads as a hard line -->
    <LinearGradientBrush x:Key="PanelEdgeGradientHorizontalSoft"
        StartPoint="0,0" EndPoint="1,0" Opacity="0.4">
        <GradientStop Color="{StaticResource ControlStrokeColorDefault}" Offset="0" />
        <GradientStop Color="Transparent" Offset="0.3" />
    </LinearGradientBrush>

</ResourceDictionary>
