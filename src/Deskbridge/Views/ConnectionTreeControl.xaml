<UserControl x:Class="Deskbridge.Views.ConnectionTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Deskbridge.ViewModels"
    xmlns:behaviors="clr-namespace:Deskbridge.Behaviors">

    <UserControl.Resources>
        <!--
             CONTEXT-MENU BINDING CONTRACT
             =============================
             These ContextMenus are x:Shared="False" resources assigned to individual
             TreeViewItems at right-click time via code-behind. Code-behind sets
             menu.DataContext = _viewModel; bindings on Command are plain
             {Binding <Command>}; CommandParameter uses PlacementTarget.DataContext.
        -->

        <!-- Connection context menu -->
        <ContextMenu x:Key="ConnectionContextMenu" x:Shared="False">
            <MenuItem Header="Connect"
                      Icon="{ui:SymbolIcon Play24}"
                      InputGestureText="Enter"
                      Command="{Binding ConnectCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="Duplicate"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding DuplicateConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Copy Hostname"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding CopyHostnameCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Group context menu -->
        <ContextMenu x:Key="GroupContextMenu" x:Shared="False">
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      Command="{Binding NewConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Multi-select context menu -->
        <ContextMenu x:Key="MultiSelectContextMenu" x:Shared="False">
            <MenuItem IsEnabled="False" FontWeight="SemiBold" x:Name="MultiSelectHeader" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Empty area context menu -->
        <ContextMenu x:Key="EmptyAreaContextMenu" x:Shared="False">
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
        </ContextMenu>

        <!--
             FULL-ROW TREEVIEWITEM TEMPLATE (WPF-TREEVIEW-PATTERNS.md Section 2)
             ===================================================================
             The default TreeViewItem template paints selection on a Grid.Column=1
             Border that only wraps the content (Border-in-DataTemplate suffers
             the same limitation). We replace the entire template so that the
             selection highlight Border spans full width, and the content inside
             is indented by depth * 19px via TreeViewItemIndentConverter.

             Selection visual is driven by the VIEWMODEL's IsSelected property
             (via a DataTrigger), NOT by TreeViewItem.IsSelected. That makes
             multi-select work: even when WPF's ChangeSelection sets native
             IsSelected=false on other items, the VM IsSelected stays true and
             the highlight stays visible.
        -->
        <Style x:Key="TreeExpanderStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="19" />
            <Setter Property="Height" Value="19" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="19" Height="19">
                            <Path x:Name="ExpandPath"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M 4,2 L 8,6 L 4,10 Z"
                                  Fill="{DynamicResource TextFillColorTertiaryBrush}"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FullRowTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- OUTER Border: no Grid.Column so it stretches to full row width -->
                            <Border x:Name="RowBorder"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    MinHeight="28"
                                    CornerRadius="{DynamicResource ControlCornerRadius}"
                                    Margin="0,0,0,1"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <!-- 2px left accent stripe (visible when selected) -->
                                    <Rectangle x:Name="AccentStripe"
                                               Width="2" Height="16"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0"
                                               RadiusX="1" RadiusY="1"
                                               Fill="{DynamicResource SystemAccentColorPrimaryBrush}"
                                               Visibility="Collapsed" />

                                    <!-- Content indented by depth * 19px -->
                                    <Grid Margin="{Binding
                                            Converter={StaticResource TreeViewItemIndent},
                                            RelativeSource={RelativeSource TemplatedParent}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="19" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton x:Name="Expander"
                                                      Grid.Column="0"
                                                      Style="{StaticResource TreeExpanderStyle}"
                                                      ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded,
                                                        RelativeSource={RelativeSource TemplatedParent}}" />

                                        <ContentPresenter x:Name="PART_Header"
                                                          Grid.Column="1"
                                                          ContentSource="Header"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Children container -->
                            <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <!--
                              Selection visual bound to the VM's IsSelected (not the
                              native TreeViewItem.IsSelected). This is what makes
                              multi-select highlight correctly — see behavior class.
                            -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"
                                        Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
                                <Setter TargetName="AccentStripe" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Search TextBox -->
            <RowDefinition Height="*" MinHeight="100" />      <!-- Row 1: TreeView -->
            <RowDefinition Height="Auto" />   <!-- Row 2: GridSplitter -->
            <!-- Row 3: Combined panel (header + body). GridSplitter resizes this row. -->
            <RowDefinition x:Name="QuickPropertiesRow" Height="200" MinHeight="28" MaxHeight="500" />
        </Grid.RowDefinitions>

        <!-- Search filter (Row 0) -->
        <ui:TextBox Grid.Row="0"
            Icon="{ui:SymbolIcon Search16}"
            PlaceholderText="Filter connections..."
            ClearButtonEnabled="True"
            Height="28"
            Margin="8,4,8,4"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <!-- TreeView (Row 1) -->
        <Grid Grid.Row="1" ContextMenu="{StaticResource EmptyAreaContextMenu}">
            <TreeView x:Name="ConnectionTree"
                      ItemsSource="{Binding RootItems}"
                      ItemContainerStyle="{StaticResource FullRowTreeViewItemStyle}"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="False"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="0"
                      behaviors:TreeViewMultiSelectBehavior.EnableMultiSelect="True"
                      behaviors:TreeViewDragDropBehavior.EnableDragDrop="True"
                      PreviewKeyDown="TreeView_PreviewKeyDown"
                      PreviewMouseDoubleClick="TreeView_PreviewMouseDoubleClick"
                      PreviewMouseRightButtonDown="TreeView_PreviewMouseRightButtonDown">
                <TreeView.Resources>
                    <!-- Group template (HierarchicalDataTemplate for nesting) -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:GroupTreeItemViewModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center">
                            <ui:SymbolIcon FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Folder24" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Symbol" Value="FolderOpen24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>

                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Key24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasCredentials, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Connection template -->
                    <DataTemplate DataType="{x:Type vm:ConnectionTreeItemViewModel}">
                        <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center"
                                    ToolTip="{Binding Hostname}">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>

            <!-- Empty tree state overlay -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        x:Name="EmptyStateOverlay">
                <TextBlock Text="No connections" FontSize="16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Right-click to create a connection or group" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- GridSplitter (Row 2) — hidden when panel collapsed -->
        <GridSplitter x:Name="PanelSplitter" Grid.Row="2"
            Height="4"
            HorizontalAlignment="Stretch"
            ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
            Visibility="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToVisibility}}"
            DragCompleted="PanelSplitter_DragCompleted" />

        <!--
             COMBINED QUICK PROPERTIES PANEL (Row 3)
             See WPF-TREEVIEW-PATTERNS.md Section 3. Header + body share a single
             Grid row so that the GridSplitter on Row 2 correctly resizes the whole
             panel (splitter's default ResizeBehavior=PreviousAndNext touches Row 1
             and Row 3). The header is a 28px strip always visible; the body is
             toggled via Visibility bound to IsQuickPropertiesExpanded. When the
             panel is collapsed, the row's Height is set to 28 from code-behind
             so only the header shows.
        -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <!-- Header strip — always visible -->
                <Border DockPanel.Dock="Top" Height="28"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="PROPERTIES"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <ui:Button Grid.Column="1"
                                   Appearance="Transparent"
                                   Width="24" Height="24"
                                   Padding="0" Margin="0,0,4,0"
                                   Command="{Binding ToggleQuickPropertiesCommand}"
                                   ToolTip="Toggle properties panel">
                            <ui:SymbolIcon
                                Symbol="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToChevron}}"
                                FontSize="12" />
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Body — hidden when collapsed -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="8,4">
                    <!-- Connection properties -->
                    <Grid Visibility="{Binding IsConnectionSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--
                             Rows (in order): Name, Hostname, Port, Credentials, Username, Domain.
                             Credentials is placed before Username/Domain so the mode selector
                             sits above the fields whose visibility/enablement it controls.
                             The Username and Domain rows use Auto height so they collapse
                             cleanly to zero height when hidden in Prompt mode.
                        -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="28" />
                            <RowDefinition Height="Auto" MinHeight="28" />
                            <RowDefinition Height="Auto" MinHeight="28" />
                            <RowDefinition Height="Auto" MinHeight="32" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="ConnectionNameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hostname"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Hostname, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="HostnameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Port, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="PortTextBox" LostFocus="QuickProperty_LostFocus" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Credentials"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <!--
                             Explicit ItemTemplate is required so SelectionBoxItem
                             renders via the same template as dropdown items. With
                             SelectedValuePath="Value", SelectionBoxItem is otherwise
                             the raw enum and WPF-UI's ComboBox template renders it
                             as "-" placeholder glyphs.
                        -->
                        <ComboBox Grid.Row="3" Grid.Column="1"
                                  ItemsSource="{Binding CredentialModes}"
                                  SelectedValue="{Binding SelectedItemCredentialMode}"
                                  SelectedValuePath="Value"
                                  FontSize="14" MinHeight="32"
                                  Margin="0,2"
                                  x:Name="CredentialModeCombo">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!--
                             Username/Domain rows: visibility and enablement follow the
                             CredentialMode. Prompt hides both rows entirely (credentials
                             requested at connect time); Inherit shows them disabled
                             (values for reference only); Own shows them enabled for edit.
                             The label TextBlocks share the same Visibility binding so the
                             rows collapse cleanly to zero height when hidden.
                        -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Username"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsQuickCredentialFieldsVisible, Converter={StaticResource BoolToVisibility}}" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Username, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 Visibility="{Binding IsQuickCredentialFieldsVisible, Converter={StaticResource BoolToVisibility}}"
                                 IsEnabled="{Binding IsQuickCredentialFieldsEnabled}"
                                 x:Name="UsernameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Password"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsQuickPasswordVisible, Converter={StaticResource BoolToVisibility}}" />
                        <PasswordBox Grid.Row="5" Grid.Column="1"
                                     Padding="4,2" FontSize="14"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                     Visibility="{Binding IsQuickPasswordVisible, Converter={StaticResource BoolToVisibility}}"
                                     x:Name="QuickPasswordBox" LostFocus="QuickPassword_LostFocus" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Domain"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsQuickCredentialFieldsVisible, Converter={StaticResource BoolToVisibility}}" />
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Domain, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 Visibility="{Binding IsQuickCredentialFieldsVisible, Converter={StaticResource BoolToVisibility}}"
                                 IsEnabled="{Binding IsQuickCredentialFieldsEnabled}"
                                 x:Name="DomainTextBox" LostFocus="QuickProperty_LostFocus" />
                    </Grid>

                    <!-- Group properties -->
                    <Grid Visibility="{Binding IsGroupSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="28" />
                            <RowDefinition Height="Auto" MinHeight="28" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="GroupNameTextBox" LostFocus="GroupQuickProperty_LostFocus" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Connections"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding PrimarySelectedItem.ConnectionCount}"
                                   FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Empty state -->
                    <TextBlock Text="Select a connection" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnectionSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsGroupSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
