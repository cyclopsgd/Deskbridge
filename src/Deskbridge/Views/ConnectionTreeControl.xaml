<UserControl x:Class="Deskbridge.Views.ConnectionTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Deskbridge.ViewModels"
    xmlns:behaviors="clr-namespace:Deskbridge.Behaviors">

    <UserControl.Resources>
        <!--
             CONTEXT-MENU BINDING CONTRACT
             =============================
             These ContextMenus are x:Shared="False" resources assigned to individual
             TreeViewItems at right-click time via code-behind. Code-behind sets
             menu.DataContext = _viewModel; bindings on Command are plain
             {Binding <Command>}; CommandParameter uses PlacementTarget.DataContext.
        -->

        <!-- Connection context menu -->
        <ContextMenu x:Key="ConnectionContextMenu" x:Shared="False">
            <MenuItem Header="Connect"
                      Icon="{ui:SymbolIcon Play24}"
                      InputGestureText="Enter"
                      Command="{Binding ConnectCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="Duplicate"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding DuplicateConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Copy Hostname"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding CopyHostnameCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Group context menu -->
        <ContextMenu x:Key="GroupContextMenu" x:Shared="False">
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      Command="{Binding NewConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Multi-select context menu -->
        <ContextMenu x:Key="MultiSelectContextMenu" x:Shared="False">
            <MenuItem IsEnabled="False" FontWeight="SemiBold" x:Name="MultiSelectHeader" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Empty area context menu -->
        <ContextMenu x:Key="EmptyAreaContextMenu" x:Shared="False">
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
        </ContextMenu>

        <!--
             FULL-ROW TREEVIEWITEM TEMPLATE (WPF-TREEVIEW-PATTERNS.md Section 2)
             ===================================================================
             The default TreeViewItem template paints selection on a Grid.Column=1
             Border that only wraps the content (Border-in-DataTemplate suffers
             the same limitation). We replace the entire template so that the
             selection highlight Border spans full width, and the content inside
             is indented by depth * 19px via TreeViewItemIndentConverter.

             Selection visual is driven by the VIEWMODEL's IsSelected property
             (via a DataTrigger), NOT by TreeViewItem.IsSelected. That makes
             multi-select work: even when WPF's ChangeSelection sets native
             IsSelected=false on other items, the VM IsSelected stays true and
             the highlight stays visible.
        -->
        <Style x:Key="TreeExpanderStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="19" />
            <Setter Property="Height" Value="19" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="19" Height="19">
                            <Path x:Name="ExpandPath"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M 4,2 L 8,6 L 4,10 Z"
                                  Fill="{DynamicResource TextFillColorTertiaryBrush}"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FullRowTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- OUTER Border: no Grid.Column so it stretches to full row width -->
                            <Border x:Name="RowBorder"
                                    BorderThickness="0"
                                    MinHeight="28"
                                    CornerRadius="{DynamicResource ControlCornerRadius}"
                                    Margin="0,0,0,1"
                                    SnapsToDevicePixels="True">
                                <Border.Background>
                                    <SolidColorBrush x:Name="RowBrush" Color="Transparent" />
                                </Border.Background>
                                <Grid>
                                    <!-- TREE-03: Vertical indent guide lines -->
                                    <ItemsControl x:Name="IndentGuides"
                                                  ItemsSource="{Binding
                                                      Converter={StaticResource DepthToGuideLines},
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                                  IsHitTestVisible="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Rectangle Width="1"
                                                           Fill="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                           Opacity="0.3"
                                                           Height="{Binding ActualHeight,
                                                               RelativeSource={RelativeSource AncestorType=Border}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 2px left accent stripe (visible when selected) -->
                                    <Rectangle x:Name="AccentStripe"
                                               Width="2" Height="16"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0"
                                               RadiusX="1" RadiusY="1"
                                               Fill="{DynamicResource SystemAccentColorPrimaryBrush}"
                                               Visibility="Collapsed" />

                                    <!-- Content indented by depth * 19px -->
                                    <Grid Margin="{Binding
                                            Converter={StaticResource TreeViewItemIndent},
                                            RelativeSource={RelativeSource TemplatedParent}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="19" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton x:Name="Expander"
                                                      Grid.Column="0"
                                                      Style="{StaticResource TreeExpanderStyle}"
                                                      ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded,
                                                        RelativeSource={RelativeSource TemplatedParent}}" />

                                        <ContentPresenter x:Name="PART_Header"
                                                          Grid.Column="1"
                                                          ContentSource="Header"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Children container -->
                            <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <!-- TREE-02: Animated hover (150ms fade-in/out) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="HoverEnter">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RowBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="{StaticResource SubtleFillColorSecondary}"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard x:Name="HoverExit">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RowBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="Transparent"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!--
                              Selection visual bound to the VM's IsSelected (not the
                              native TreeViewItem.IsSelected). This is what makes
                              multi-select highlight correctly — see behavior class.
                              Uses EnterActions/ExitActions so the animation overrides any
                              running hover animation (WPF: later Storyboard wins).
                              AccentStripe visibility is still via Setter (instant, correct).
                            -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="SelectEnter">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RowBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="{StaticResource SystemAccentColorSecondary}"
                                                Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard x:Name="SelectExit">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RowBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="Transparent"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                                <Setter TargetName="AccentStripe" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Search TextBox -->
            <RowDefinition Height="*" MinHeight="100" />      <!-- Row 1: TreeView -->
            <RowDefinition Height="Auto" />   <!-- Row 2: GridSplitter -->
            <!-- Row 3: Combined panel (header + body). GridSplitter resizes this row. -->
            <RowDefinition x:Name="QuickPropertiesRow" Height="290" MinHeight="28" MaxHeight="500" />
        </Grid.RowDefinitions>

        <!-- Search filter (Row 0) -->
        <ui:TextBox Grid.Row="0"
            Icon="{ui:SymbolIcon Search16}"
            PlaceholderText="Filter connections..."
            ClearButtonEnabled="True"
            Height="28"
            Margin="8,4,8,4"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <!-- TreeView (Row 1) -->
        <Grid Grid.Row="1" ContextMenu="{StaticResource EmptyAreaContextMenu}">
            <TreeView x:Name="ConnectionTree"
                      ItemsSource="{Binding RootItems}"
                      ItemContainerStyle="{StaticResource FullRowTreeViewItemStyle}"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="False"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="0"
                      behaviors:TreeViewMultiSelectBehavior.EnableMultiSelect="True"
                      behaviors:TreeViewDragDropBehavior.EnableDragDrop="True"
                      PreviewKeyDown="TreeView_PreviewKeyDown"
                      PreviewMouseDoubleClick="TreeView_PreviewMouseDoubleClick"
                      PreviewMouseRightButtonDown="TreeView_PreviewMouseRightButtonDown">
                <TreeView.Resources>
                    <!-- Group template (HierarchicalDataTemplate for nesting) -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:GroupTreeItemViewModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center">
                            <ui:SymbolIcon FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Folder24" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Symbol" Value="FolderOpen24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>

                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />

                            <ui:SymbolIcon Symbol="Key24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasCredentials, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Connection template -->
                    <DataTemplate DataType="{x:Type vm:ConnectionTreeItemViewModel}">
                        <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center"
                                    ToolTip="{Binding Hostname}">
                            <!-- TREE-01: Status dot (8x8, colored by per-item ConnectionState) -->
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Margin="0,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <!-- Default: gray (disconnected / no active tab) -->
                                        <Setter Property="Fill"
                                                Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionState}"
                                                         Value="Connected">
                                                <Setter Property="Fill"
                                                        Value="{DynamicResource DeskbridgeSuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionState}"
                                                         Value="Connecting">
                                                <Setter Property="Fill"
                                                        Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionState}"
                                                         Value="Reconnecting">
                                                <Setter Property="Fill"
                                                        Value="{DynamicResource DeskbridgeWarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConnectionState}"
                                                         Value="Error">
                                                <Setter Property="Fill"
                                                        Value="{DynamicResource DeskbridgeErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource BodyStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>

            <!-- Empty tree state overlay -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        x:Name="EmptyStateOverlay">
                <TextBlock Text="No connections" FontSize="16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Right-click to create a connection or group"
                           Style="{StaticResource HintStyle}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- GridSplitter (Row 2) — hidden when panel collapsed -->
        <GridSplitter x:Name="PanelSplitter" Grid.Row="2"
            Height="4"
            HorizontalAlignment="Stretch"
            ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
            Visibility="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToVisibility}}"
            DragCompleted="PanelSplitter_DragCompleted" />

        <!--
             COMBINED QUICK PROPERTIES PANEL (Row 3)
             Phase 9: Redesigned with collapsible card sections (CONNECTION, CREDENTIALS),
             status dot in header, and read-only field styling for inherited credentials.
             See WPF-TREEVIEW-PATTERNS.md Section 3. Header + body share a single
             Grid row so that the GridSplitter on Row 2 correctly resizes the whole
             panel (splitter's default ResizeBehavior=PreviousAndNext touches Row 1
             and Row 3). The header is a 28px strip always visible; the body is
             toggled via Visibility bound to IsQuickPropertiesExpanded. When the
             panel is collapsed, the row's Height is set to 28 from code-behind
             so only the header shows.
        -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <!-- Header strip — always visible -->
                <Border DockPanel.Dock="Top"
                        Style="{StaticResource PanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="PROPERTIES"
                                   Style="{StaticResource SectionLabelStyle}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />

                        <!-- Phase 9 (D-03): Status dot — 8px colored circle showing connection state.
                             Visible only when a connection (not a group) is selected.
                             Gray = disconnected/no session, Green = connected, Amber = reconnecting, Red = error. -->
                        <Ellipse Grid.Column="1" Width="8" Height="8"
                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                 Visibility="{Binding IsConnectionSelected, Converter={StaticResource BoolToVisibility}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <!-- Default: gray (disconnected / no active tab / connecting) -->
                                    <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedConnectionState}" Value="Connected">
                                            <Setter Property="Fill" Value="{DynamicResource DeskbridgeSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedConnectionState}" Value="Reconnecting">
                                            <Setter Property="Fill" Value="{DynamicResource DeskbridgeWarningBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedConnectionState}" Value="Error">
                                            <Setter Property="Fill" Value="{DynamicResource DeskbridgeErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <ui:Button Grid.Column="3"
                                   Appearance="Transparent"
                                   Width="24" Height="24"
                                   Padding="0" Margin="0,0,4,0"
                                   Command="{Binding ToggleQuickPropertiesCommand}"
                                   ToolTip="Toggle properties panel">
                            <ui:SymbolIcon
                                Symbol="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToChevron}}"
                                FontSize="12" />
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Body — hidden when collapsed. Padding="0,0,4,0" prevents scrollbar overlapping fields. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsQuickPropertiesExpanded, Converter={StaticResource BoolToVisibility}}"
                              Padding="0,0,4,0">
                    <Grid>
                        <!-- Connection properties — shown when a connection is selected -->
                        <StackPanel Visibility="{Binding IsConnectionSelected, Converter={StaticResource BoolToVisibility}}"
                                    Margin="8,4,8,8">

                            <!-- === CONNECTION CARD (D-01) === -->
                            <Border Style="{StaticResource CardContainerStyle}" Margin="0,0,0,8">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Top"
                                                  IsChecked="{Binding IsConnectionCardExpanded}"
                                                  Style="{StaticResource CardHeaderToggleStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="CONNECTION"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       VerticalAlignment="Center" />
                                            <ui:SymbolIcon Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Symbol="{Binding IsConnectionCardExpanded,
                                                    Converter={StaticResource BoolToChevron}}"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </ToggleButton>

                                    <Grid Visibility="{Binding IsConnectionCardExpanded,
                                              Converter={StaticResource BoolToVisibility}}"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4" />
                                        <ui:TextBox Grid.Row="0" Grid.Column="1"
                                                    Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="14" Margin="0,4"
                                                    x:Name="ConnectionNameTextBox"
                                                    LostFocus="QuickProperty_LostFocus" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hostname"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4" />
                                        <ui:TextBox Grid.Row="1" Grid.Column="1"
                                                    Text="{Binding PrimarySelectedItem.Hostname, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="14" Margin="0,4"
                                                    x:Name="HostnameTextBox"
                                                    LostFocus="QuickProperty_LostFocus" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4" />
                                        <ui:TextBox Grid.Row="2" Grid.Column="1"
                                                    Text="{Binding PrimarySelectedItem.Port, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="14" Margin="0,4"
                                                    x:Name="PortTextBox"
                                                    LostFocus="QuickProperty_LostFocus" />
                                    </Grid>
                                </DockPanel>
                            </Border>

                            <!-- === CREDENTIALS CARD (D-01) === -->
                            <Border Style="{StaticResource CardContainerStyle}" Margin="0,0,0,0">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Top"
                                                  IsChecked="{Binding IsCredentialsCardExpanded}"
                                                  Style="{StaticResource CardHeaderToggleStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="CREDENTIALS"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       VerticalAlignment="Center" />
                                            <ui:SymbolIcon Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Symbol="{Binding IsCredentialsCardExpanded,
                                                    Converter={StaticResource BoolToChevron}}"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </ToggleButton>

                                    <Grid Visibility="{Binding IsCredentialsCardExpanded,
                                              Converter={StaticResource BoolToVisibility}}"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Credential Mode — always editable (D-05) -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4" />
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding CredentialModes}"
                                                  SelectedValue="{Binding SelectedItemCredentialMode}"
                                                  SelectedValuePath="Value"
                                                  FontSize="14" Margin="0,4"
                                                  x:Name="CredentialModeCombo"
                                                  PreviewMouseWheel="ComboBox_PreviewMouseWheel">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!-- Username — editable when Own, read-only when Inherit (D-05, D-06) -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4"
                                                   Visibility="{Binding IsQuickCredentialFieldsVisible,
                                                       Converter={StaticResource BoolToVisibility}}" />
                                        <!-- Editable: shown when CredentialMode == Own -->
                                        <ui:TextBox Grid.Row="1" Grid.Column="1"
                                                    Text="{Binding PrimarySelectedItem.Username, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="14" Margin="0,4"
                                                    x:Name="UsernameTextBox"
                                                    LostFocus="QuickProperty_LostFocus">
                                            <ui:TextBox.Style>
                                                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsVisible}" Value="True" />
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsEnabled}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:TextBox.Style>
                                        </ui:TextBox>
                                        <!-- Read-only: shown when CredentialMode == Inherit (D-06) -->
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding PrimarySelectedItem.Username}"
                                                   Margin="0,4">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ReadOnlyFieldStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsVisible}" Value="True" />
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsEnabled}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Password — only shown in Own mode (D-05) -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Password"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4"
                                                   Visibility="{Binding IsQuickPasswordVisible,
                                                       Converter={StaticResource BoolToVisibility}}" />
                                        <ui:PasswordBox Grid.Row="2" Grid.Column="1"
                                                        FontSize="14" Margin="0,4"
                                                        Visibility="{Binding IsQuickPasswordVisible,
                                                            Converter={StaticResource BoolToVisibility}}"
                                                        x:Name="QuickPasswordBox"
                                                        GotFocus="QuickPassword_GotFocus"
                                                        LostFocus="QuickPassword_LostFocus"
                                                        PasswordChanged="QuickPassword_PasswordChanged" />

                                        <!-- Domain — editable when Own, read-only when Inherit (D-05, D-06) -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Domain"
                                                   Style="{StaticResource FieldLabelCompactStyle}"
                                                   Margin="0,4"
                                                   Visibility="{Binding IsQuickCredentialFieldsVisible,
                                                       Converter={StaticResource BoolToVisibility}}" />
                                        <!-- Editable: shown when CredentialMode == Own -->
                                        <ui:TextBox Grid.Row="3" Grid.Column="1"
                                                    Text="{Binding PrimarySelectedItem.Domain, UpdateSourceTrigger=LostFocus}"
                                                    FontSize="14" Margin="0,4"
                                                    x:Name="DomainTextBox"
                                                    LostFocus="QuickProperty_LostFocus">
                                            <ui:TextBox.Style>
                                                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsVisible}" Value="True" />
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsEnabled}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:TextBox.Style>
                                        </ui:TextBox>
                                        <!-- Read-only: shown when CredentialMode == Inherit (D-06) -->
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding PrimarySelectedItem.Domain}"
                                                   Margin="0,4">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ReadOnlyFieldStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsVisible}" Value="True" />
                                                                <Condition Binding="{Binding IsQuickCredentialFieldsEnabled}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <!-- Group properties — shown when a group is selected -->
                        <Grid Visibility="{Binding IsGroupSelected, Converter={StaticResource BoolToVisibility}}"
                              Margin="8,4,8,8">
                            <Border Style="{StaticResource CardContainerStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" MinHeight="28" />
                                        <RowDefinition Height="Auto" MinHeight="28" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                               Style="{StaticResource FieldLabelCompactStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                             Height="24" Padding="4,4" FontSize="14"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             x:Name="GroupNameTextBox"
                                             LostFocus="GroupQuickProperty_LostFocus" />

                                    <!-- Connections count — read-only computed value (D-06) -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Connections"
                                               Style="{StaticResource FieldLabelCompactStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PrimarySelectedItem.ConnectionCount}"
                                               Style="{StaticResource ReadOnlyFieldStyle}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Empty state -->
                        <TextBlock Text="Select a connection" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnectionSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsGroupSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
