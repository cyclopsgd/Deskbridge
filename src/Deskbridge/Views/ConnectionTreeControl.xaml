<UserControl x:Class="Deskbridge.Views.ConnectionTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Deskbridge.ViewModels"
    xmlns:behaviors="clr-namespace:Deskbridge.Behaviors">

    <UserControl.Resources>
        <!--
             CONTEXT-MENU BINDING CONTRACT
             =============================
             These ContextMenus are stored as shared (default x:Shared=True) resources and assigned
             to individual TreeViewItems at right-click time via code-behind. Because the menu's
             logical parent chain does NOT include the TreeView (it is rooted in the UserControl
             that owns the resource), bindings using RelativeSource AncestorType=TreeView fail
             silently — that was the root cause of Edit / Rename / Duplicate / Copy Hostname /
             Delete etc doing nothing on right-click.

             Correct pattern:
               * The code-behind sets menu.DataContext = _viewModel (the tree VM).
                 -> Command bindings become {Binding <Command>} with no RelativeSource.
               * CommandParameter pulls the item VM via PlacementTarget.DataContext on the menu.
                 PlacementTarget = TreeViewItem, whose DataContext = the item VM.
        -->

        <!-- Connection context menu -->
        <ContextMenu x:Key="ConnectionContextMenu" x:Shared="False">
            <MenuItem Header="Connect"
                      Icon="{ui:SymbolIcon Play24}"
                      InputGestureText="Enter"
                      Command="{Binding ConnectCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="Rename"
                      Icon="{ui:SymbolIcon Rename24}"
                      InputGestureText="F2"
                      Command="{Binding RenameItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="Duplicate"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding DuplicateConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Copy Hostname"
                      Icon="{ui:SymbolIcon Copy24}"
                      Command="{Binding CopyHostnameCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Group context menu -->
        <ContextMenu x:Key="GroupContextMenu" x:Shared="False">
            <MenuItem Header="Edit"
                      Icon="{ui:SymbolIcon Edit24}"
                      Command="{Binding EditItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="Rename"
                      Icon="{ui:SymbolIcon Rename24}"
                      InputGestureText="F2"
                      Command="{Binding RenameItemCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <Separator />
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      Command="{Binding NewConnectionCommand}"
                      CommandParameter="{Binding PlacementTarget.DataContext.Id, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <Separator />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Multi-select context menu -->
        <ContextMenu x:Key="MultiSelectContextMenu" x:Shared="False">
            <MenuItem IsEnabled="False" FontWeight="SemiBold" x:Name="MultiSelectHeader" />
            <Separator />
            <MenuItem Header="Move to..."
                      Icon="{ui:SymbolIcon ArrowMove24}" />
            <MenuItem Header="Delete"
                      Icon="{ui:SymbolIcon Delete24}"
                      InputGestureText="Delete"
                      Foreground="{DynamicResource DeskbridgeErrorBrush}"
                      Command="{Binding DeleteSelectedCommand}" />
        </ContextMenu>

        <!-- Empty area context menu (attached directly to the UserControl's Grid; DataContext is the tree VM) -->
        <ContextMenu x:Key="EmptyAreaContextMenu" x:Shared="False">
            <MenuItem Header="New Connection"
                      Icon="{ui:SymbolIcon Add24}"
                      InputGestureText="Ctrl+N"
                      Command="{Binding NewConnectionCommand}" />
            <MenuItem Header="New Group"
                      Icon="{ui:SymbolIcon FolderAdd24}"
                      Command="{Binding NewGroupCommand}" />
        </ContextMenu>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Search TextBox -->
            <RowDefinition Height="*" />      <!-- Row 1: TreeView -->
            <RowDefinition Height="Auto" />   <!-- Row 2: GridSplitter -->
            <RowDefinition x:Name="QuickPropertiesRow" Height="120" MinHeight="0" MaxHeight="200" /> <!-- Row 3: Quick properties -->
        </Grid.RowDefinitions>

        <!-- Search filter (Row 0) -->
        <ui:TextBox Grid.Row="0"
            Icon="{ui:SymbolIcon Search16}"
            PlaceholderText="Filter connections..."
            ClearButtonEnabled="True"
            Height="28"
            Margin="8,4,8,4"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <!-- TreeView (Row 1) -->
        <Grid Grid.Row="1" ContextMenu="{StaticResource EmptyAreaContextMenu}">
            <!-- TreeView content -->
            <TreeView x:Name="ConnectionTree"
                      ItemsSource="{Binding RootItems}"
                      VirtualizingPanel.IsVirtualizing="False"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="0"
                      behaviors:TreeViewMultiSelectBehavior.EnableMultiSelect="True"
                      behaviors:TreeViewDragDropBehavior.EnableDragDrop="True"
                      PreviewKeyDown="TreeView_PreviewKeyDown"
                      PreviewMouseDoubleClick="TreeView_PreviewMouseDoubleClick"
                      PreviewMouseRightButtonDown="TreeView_PreviewMouseRightButtonDown">
                <TreeView.Resources>
                    <!-- Group template (HierarchicalDataTemplate for nesting) -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:GroupTreeItemViewModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Height="28" Margin="4,2">
                            <!-- Folder icon: FolderOpen24 when expanded, Folder24 when collapsed -->
                            <ui:SymbolIcon FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Folder24" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                <Setter Property="Symbol" Value="FolderOpen24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>

                            <!-- Group name (TextBlock, hidden when renaming) -->
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibility}}" />

                            <!-- Rename TextBox (visible when renaming) -->
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Height="24" Padding="4,2" FontSize="14"
                                     Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibility}}"
                                     KeyDown="RenameTextBox_KeyDown"
                                     LostFocus="RenameTextBox_LostFocus"
                                     Loaded="RenameTextBox_Loaded" />

                            <!-- Key icon for groups with credentials (CONN-10) -->
                            <ui:SymbolIcon Symbol="Key24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasCredentials, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Connection template (flat DataTemplate) -->
                    <DataTemplate DataType="{x:Type vm:ConnectionTreeItemViewModel}">
                        <StackPanel Orientation="Horizontal" Height="28" Margin="4,2"
                                    ToolTip="{Binding Hostname}">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="16" Margin="0,0,4,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <!-- Connection name (TextBlock, hidden when renaming) -->
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibility}}" />

                            <!-- Rename TextBox (visible when renaming) -->
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Height="24" Padding="4,2" FontSize="14"
                                     Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibility}}"
                                     KeyDown="RenameTextBox_KeyDown"
                                     LostFocus="RenameTextBox_LostFocus"
                                     Loaded="RenameTextBox_Loaded" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>

                <!-- ItemContainerStyle for selection/expansion binding -->
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="Padding" Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                <Setter Property="BorderThickness" Value="2,0,0,0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

            <!-- Empty tree state overlay -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        x:Name="EmptyStateOverlay">
                <TextBlock Text="No connections" FontSize="16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Right-click to create a connection or group" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- GridSplitter (Row 2) -->
        <GridSplitter Grid.Row="2"
            Height="4"
            HorizontalAlignment="Stretch"
            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
            Visibility="{Binding IsQuickPropertiesVisible, Converter={StaticResource BoolToVisibility}}" />

        <!-- Quick Properties Panel (Row 3) -->
        <Border Grid.Row="3"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{Binding IsQuickPropertiesVisible, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Properties header -->
                <DockPanel DockPanel.Dock="Top" Height="24" Margin="8,0">
                    <TextBlock Text="PROPERTIES" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <ui:Button DockPanel.Dock="Right"
                        Appearance="Transparent"
                        Width="20" Height="20"
                        Padding="0"
                        HorizontalAlignment="Right"
                        Command="{Binding ToggleQuickPropertiesCommand}">
                        <ui:SymbolIcon Symbol="ChevronDown16" FontSize="12" />
                    </ui:Button>
                </DockPanel>

                <!-- Properties content area (scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="8,4">
                    <!-- Connection properties (when connection selected) -->
                    <Grid Visibility="{Binding IsConnectionSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <!-- Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="ConnectionNameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <!-- Hostname -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hostname"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Hostname, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="HostnameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <!-- Port -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Port, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="PortTextBox" LostFocus="QuickProperty_LostFocus" />

                        <!-- Username -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Username"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Username, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="UsernameTextBox" LostFocus="QuickProperty_LostFocus" />

                        <!-- Credentials mode -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Credentials"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Row="4" Grid.Column="1"
                                  SelectedItem="{Binding PrimarySelectedItem.CredentialMode}"
                                  Height="24" FontSize="14"
                                  x:Name="CredentialModeCombo"
                                  SelectionChanged="CredentialMode_SelectionChanged" />
                    </Grid>

                    <!-- Group properties (when group selected) -->
                    <Grid Visibility="{Binding IsGroupSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <!-- Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding PrimarySelectedItem.Name, UpdateSourceTrigger=LostFocus}"
                                 Height="24" Padding="4,2" FontSize="14"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 x:Name="GroupNameTextBox" LostFocus="GroupQuickProperty_LostFocus" />

                        <!-- Connections count -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Connections"
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding PrimarySelectedItem.ConnectionCount}"
                                   FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Empty state (nothing selected) -->
                    <TextBlock Text="Select a connection" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnectionSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsGroupSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
